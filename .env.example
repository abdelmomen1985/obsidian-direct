# Absolute path to your Obsidian vault directory
VAULT_PATH=/home/you/vault

# Port to bind the HTTP server on (default: 3000)
PORT=3000

# Argon2id (or bcrypt on older Bun) hash of your password — generate with: bun run hash
AUTH_PASSWORD_HASH=$argon2id$v=19$m=65536,t=2,p=1$...

# Random secret for HMAC-signing session cookies — generate with:
#   openssl rand -hex 32
SESSION_SECRET=change_me_to_a_long_random_string

# Session lifetime in seconds (default: 604800 = 7 days)
SESSION_TTL=604800
