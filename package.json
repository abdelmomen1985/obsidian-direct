{
  "name": "obsidian-direct",
  "version": "1.0.0",
  "description": "Web editor for Obsidian vaults over SSH",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run --watch src/server.ts\" \"bun build web/main.ts --outdir dist/web --watch --target browser\"",
    "build": "bun build web/main.ts --outdir dist/web --minify --target browser",
    "start": "bun run src/server.ts",
    "hash": "bun run scripts/hash-password.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/language": "^6.10.8",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.36.3",
    "codemirror": "^6.0.1",
    "dompurify": "^3.2.4",
    "marked": "^15.0.7"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "bun-types": "latest",
    "concurrently": "^9.1.2"
  }
}
